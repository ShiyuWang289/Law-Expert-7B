# phase_c/citation_formatter.py
"""
引用溯源格式化模块

工业级RAG必须支持引用溯源，原因：
1. 可信度：用户能核实回答的法律依据
2. 可调试：开发者能追溯"模型为何这么回答"
3. 对抗断章取义：展示原文片段，让误读可见

输出格式（结构化）：
{
  "answer": "根据《劳动合同法》...",
  "citations": [
    {
      "source_id":       "劳动合同法_第四十七条",
      "law_name":        "《劳动合同法》",
      "article":         "第四十七条",
      "snippet":         "经济补偿按劳动者在本单位工作的年限...",
      "relevance_score": 0.923,
      "rank":            1
    }
  ]
}

Prompt中的引用指令：
在System Prompt末尾加入强制引用要求，
让模型在回答末尾主动标注【来源：XXX】
"""

import re


def build_citation_prompt(
    base_system_prompt: str,
    retrieved_chunks:   list[dict]
) -> tuple[str, list[dict]]:
    """
    构建带引用溯源的增强Prompt。

    Returns:
        (augmented_prompt, citation_metadata)
        citation_metadata 用于后处理时匹配模型引用与实际chunk
    """
    if not retrieved_chunks:
        return base_system_prompt, []

    # 为每个chunk分配source_id
    citation_metadata = []
    context_lines = ["【参考法条】（系统检索结果，请优先参考并在回答末尾标注来源）\n"]

    for i, chunk in enumerate(retrieved_chunks):
        # 生成source_id
        article_clean = re.sub(r'[《》\s]', '', chunk.get("article", f"chunk_{i}"))
        source_id     = f"{chunk['source'].replace('.txt','').replace('_','')}__{article_clean}"

        citation_metadata.append({
            "source_id":       source_id,
            "law_name":        chunk.get("law_name", chunk["source"].replace(".txt", "")),
            "article":         chunk.get("article", ""),
            "snippet":         chunk["text"][:150],  # 前150字作为片段摘要
            "full_text":       chunk["text"],
            "relevance_score": chunk.get("rerank_score", chunk.get("rrf_score", 0.0)),
            "rank":            i + 1
        })

        context_lines.append(
            f"[来源{i+1}: {source_id}]\n{chunk['text']}\n"
        )

    context = "\n".join(context_lines)

    # 引用指令（追加到System Prompt末尾）
    citation_instruction = """

## 引用规范（必须遵守）
回答末尾必须用以下格式标注所引用的法条来源：
【来源：source_id】
例如：【来源：劳动合同法__第四十七条】

如果引用了多条法条，每条单独一行标注。
未在参考法条中出现的法律依据，请注明"（模型知识，请核实）"。"""

    augmented_prompt = f"{base_system_prompt}{citation_instruction}\n\n{context}"

    return augmented_prompt, citation_metadata


def extract_citations(
    model_answer:      str,
    citation_metadata: list[dict]
) -> list[dict]:
    """
    从模型回答中提取引用标注，与元数据匹配。

    解析模型输出的【来源：XXX】格式
    匹配到citation_metadata中的实际chunk
    """
    # 提取模型标注的source_id
    pattern = r'【来源[：:]\s*([^\】]+)】'
    cited_ids = re.findall(pattern, model_answer)

    matched_citations = []
    unmatched_ids     = []

    for cited_id in cited_ids:
        cited_id = cited_id.strip()
        # 在metadata中查找匹配
        match = next(
            (m for m in citation_metadata if m["source_id"] == cited_id),
            None
        )
        if match:
            matched_citations.append(match)
        else:
            unmatched_ids.append(cited_id)

    return {
        "matched":   matched_citations,
        "unmatched": unmatched_ids,
        "total_cited": len(cited_ids),
        "citation_rate": len(matched_citations) / max(len(citation_metadata), 1)
    }


def format_final_output(
    question:          str,
    answer:            str,
    citation_metadata: list[dict],
    latency:           float
) -> dict:
    """
    构建最终结构化输出（面试展示用）
    """
    citation_result = extract_citations(answer, citation_metadata)

    return {
        "question": question,
        "answer":   answer,
        "citations": [
            {
                "source_id":       c["source_id"],
                "article":         c["article"],
                "snippet":         c["snippet"],
                "relevance_score": round(c["relevance_score"], 4),
                "rank":            c["rank"]
            }
            for c in citation_result["matched"]
        ],
        "citation_stats": {
            "retrieved_count":  len(citation_metadata),
            "cited_count":      citation_result["total_cited"],
            "matched_count":    len(citation_result["matched"]),
            "citation_rate":    round(citation_result["citation_rate"], 3),
            "unmatched_ids":    citation_result["unmatched"]
        },
        "latency_s": round(latency, 2)
    }
    